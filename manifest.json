{
  "manifest_version": 3,
  "name": "TB Account Sender",
  "version": "1.0",
  "description": "Sends the user's account and message data to a PHP script",
  "permissions": [
    "accountsRead",
    "messagesRead"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Send data to PHP"
  }
}